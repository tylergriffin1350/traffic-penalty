{
  "name": "web",
  "dockerFile": "Dockerfile",
  "customizations": {
    "vscode": {
      "extensions": [
        "docsmsft.docs-markdown"
      ],
      "settings": {
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          }
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.detectIndentation": false,
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      }
    }
  }
}